# ============================================================
# SOBRE RUEDAS — Variables de Entorno
# Copiá este archivo a .env.local (Next.js) y .env (server)
# ============================================================

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Mercado Pago ---
MP_ACCESS_TOKEN=your-mp-access-token
MP_PUBLIC_KEY=your-mp-public-key
MP_WEBHOOK_SECRET=your-mp-webhook-secret

# --- PayPal ---
PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_CLIENT_SECRET=your-paypal-client-secret
PAYPAL_MODE=sandbox  # sandbox | live

# --- MODO (Argentina) ---
MODO_API_KEY=your-modo-api-key
MODO_MERCHANT_ID=your-modo-merchant-id

# --- Nave ---
NAVE_API_KEY=your-nave-api-key
NAVE_MERCHANT_ID=your-nave-merchant-id

# --- Payway ---
PAYWAY_MERCHANT_ID=your-payway-merchant-id
PAYWAY_API_KEY=your-payway-api-key
PAYWAY_SECRET_KEY=your-payway-secret-key

# --- WhatsApp ---
NEXT_PUBLIC_WHATSAPP_NUMBER=5491112345678

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
SERVER_PORT=4000
NODE_ENV=development

# --- JWT (para API interna) ---
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
